<Page x:Class="Cinema.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="WelcomePage" Background="#F4F7F6"
      FontFamily="Segoe UI">

    <Page.Resources>
        <DropShadowEffect x:Key="SoftShadow" BlurRadius="20" ShadowDepth="5" Direction="270" Color="#30000000" Opacity="0.2"/>

        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
            <Setter Property="Margin" Value="10"/>
        </Style>

        <Style TargetType="Border" x:Key="MovieCard">
            <Setter Property="Background" Value="#1E2B3C"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="Margin" Value="10,15,10,15"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="3" Color="Black" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10,0,0,25">
            <TextBlock Text="👋 Chào mừng đến với Hệ thống Quản lý!" 
                       FontSize="30" FontWeight="ExtraBold" Foreground="#2C3E50"/>
            <TextBlock Text="Theo dõi tổng quan dữ liệu rạp phim của bạn hôm nay." 
                       FontSize="16" Foreground="#7F8C8D" Margin="0,8,0,0"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="4" Rows="1" Margin="0,0,0,20">
            <Border Style="{StaticResource DashboardCard}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF7675" Offset="0.0"/>
                        <GradientStop Color="#D63031" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="🎬 Phim Đang Chiếu" Foreground="White" FontSize="16" FontWeight="SemiBold" Opacity="0.9"/>
                    <TextBlock x:Name="TxtPhimCount" Text="08" Foreground="White" FontSize="42" FontWeight="Bold" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardCard}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#74B9FF" Offset="0.0"/>
                        <GradientStop Color="#0984E3" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="🕒 Suất Chiếu Hôm Nay" Foreground="White" FontSize="16" FontWeight="SemiBold" Opacity="0.9"/>
                    <TextBlock x:Name="TxtLichChieuCount" Text="21" Foreground="White" FontSize="42" FontWeight="Bold" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardCard}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#55EFC4" Offset="0.0"/>
                        <GradientStop Color="#00B894" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="🍿 SP &amp; Combo Đang Bán" Foreground="White" FontSize="16" FontWeight="SemiBold" Opacity="0.9"/>
                    <TextBlock x:Name="TxtSanPhamCount" Text="10" Foreground="White" FontSize="42" FontWeight="Bold" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardCard}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFEAA7" Offset="0.0"/>
                        <GradientStop Color="#FDCB6E" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="🚪 Rạp Hoạt Động" Foreground="#2D3436" FontSize="16" FontWeight="SemiBold" Opacity="0.9"/>
                    <TextBlock x:Name="TxtPhongCount" Text="09" Foreground="#2D3436" FontSize="42" FontWeight="Bold" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Background="White" CornerRadius="20" Margin="10" Padding="20" Effect="{StaticResource SoftShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="🔥 PHIM ĐANG HOT" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="10,0,0,15"/>

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,5" HorizontalAlignment="Center" VerticalAlignment="Top">

                        <Border Style="{StaticResource MovieCard}">
                            <StackPanel>
                                <Border Height="240" CornerRadius="15,15,0,0">
                                    <Border.Background>
                                        <ImageBrush ImageSource="https://couplecinema.vn/wp-content/uploads/2024/04/3587a6cd29f779d19e235bc39b28d4a4-691x1024.jpg" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="DUNE: HÀNH TINH CÁT 2" Foreground="White" FontWeight="Bold" FontSize="15" Margin="15,15,15,5" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="Viễn tưởng, Hành động | 166p" Foreground="#BDC3C7" FontSize="12" Margin="15,0,15,15"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource MovieCard}">
                            <StackPanel>
                                <Border Height="240" CornerRadius="15,15,0,0">
                                    <Border.Background>
                                        <ImageBrush ImageSource="https://www.elle.vn/wp-content/uploads/2023/12/06/560540/poster-Mai-scaled.jpg" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="MAI (18+)" Foreground="White" FontWeight="Bold" FontSize="15" Margin="15,15,15,5" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="Tâm lý, Tình cảm | 131p" Foreground="#BDC3C7" FontSize="12" Margin="15,0,15,15"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource MovieCard}">
                            <StackPanel>
                                <Border Height="240" CornerRadius="15,15,0,0">
                                    <Border.Background>
                                        <ImageBrush ImageSource="https://image.tmdb.org/t/p/w500/kDp1vUBnMpe8ak4rjgl3cLELqjU.jpg" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="KUNG FU PANDA 4" Foreground="White" FontWeight="Bold" FontSize="15" Margin="15,15,15,5" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="Hoạt hình, Hài hước | 94p" Foreground="#BDC3C7" FontSize="12" Margin="15,0,15,15"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource MovieCard}">
                            <StackPanel>
                                <Border Height="240" CornerRadius="15,15,0,0">
                                    <Border.Background>
                                        <ImageBrush ImageSource="https://media.yeah1.com/files/thientruc/2024/03/27/quat-mo-trung-ma-an-y-canh-con-trai-truong-chao-gay-ron-nguoi-11-102049.jpg" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="EXHUMA: QUẬT MỘ TRÙNG MA" Foreground="White" FontWeight="Bold" FontSize="15" Margin="15,15,15,5" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="Kinh dị, Giật gân | 134p" Foreground="#BDC3C7" FontSize="12" Margin="15,0,15,15"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
