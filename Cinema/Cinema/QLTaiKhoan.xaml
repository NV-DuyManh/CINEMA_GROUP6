<Page x:Class="Cinema.QLTaiKhoan"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Cinema"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="Quản Lý Tài Khoản" Background="#F4F7F9">

    <Page.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" BorderBrush="#DDE2E8" BorderThickness="1" Background="White" CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="QUẢN LÝ TÀI KHOẢN NGƯỜI DÙNG" 
                   FontSize="22" FontWeight="Bold" Foreground="#2C3E50" 
                   Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="Gray" Opacity="0.2" ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="10,5">
                    <TextBlock Text="Tài khoản" Foreground="#7F8C8D" Margin="0,0,0,5" FontSize="11" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtTaiKhoan" Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,5">
                    <TextBlock Text="Mật khẩu" Foreground="#7F8C8D" Margin="0,0,0,5" FontSize="11" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtMatKhau" Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="10,5">
                    <TextBlock Text="Họ tên" Foreground="#7F8C8D" Margin="0,0,0,5" FontSize="11" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtHoTen" Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="10,5">
                    <TextBlock Text="Chức vụ" Foreground="#7F8C8D" Margin="0,0,0,5" FontSize="11" FontWeight="SemiBold"/>
                    <ComboBox x:Name="cbChucVu" Height="35" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Admin"/>
                        <ComboBoxItem Content="Staff"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,5">
                    <TextBlock Text="Tìm kiếm" Foreground="#7F8C8D" Margin="0,0,0,5" FontSize="11" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtSearch" Style="{StaticResource ModernTextBox}" Tag="Nhập tên..."/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,5,0">
                    <Button x:Name="btnThem" Click="btnThem_Click" Content="Thêm mới" Background="#27AE60" Style="{StaticResource ModernButton}"/>
                    <Button x:Name="btnSua" Click="btnSua_Click" Content="Cập nhật" Background="#2980B9" Style="{StaticResource ModernButton}"/>
                    <Button x:Name="btnXoa" Click="btnXoa_Click" Content="Xóa" Background="#E74C3C" Style="{StaticResource ModernButton}"/>
                    <Button x:Name="btnLamMoi" Click="btnLamMoi_Click" Content="Làm mới" Background="#95A5A6" Style="{StaticResource ModernButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="5">
            <DataGrid x:Name="dgNguoiDung" SelectionChanged="dgNguoiDung_SelectionChanged" 
                      AutoGenerateColumns="False" CanUserAddRows="False"
                      Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal"
                      RowHeight="38" SelectionUnit="FullRow" IsReadOnly="True">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2C3E50"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Height" Value="35"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã NV" Binding="{Binding ma_nguoi_dung}" Width="70"/>
                    <DataGridTextColumn Header="Tài khoản" Binding="{Binding tai_khoan}" Width="*"/>
                    <DataGridTextColumn Header="Mật khẩu" Binding="{Binding mat_khau}" Width="*"/>
                    <DataGridTextColumn Header="Họ tên" Binding="{Binding ho_ten}" Width="2*"/>
                    <DataGridTextColumn Header="Chức vụ" Binding="{Binding chuc_vu}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>