<Window x:Class="Cinema.WindowThemPhim"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm phim"
        Height="600"
        Width="800"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9">

    <Window.Resources>

        <!-- Label Style -->
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#D0D7DE"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Button Style -->
        <Style TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Window.Resources>

    <Border Background="White"
            CornerRadius="12"
            Padding="30"
            Margin="20">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <TextBlock Text="🎬 Thêm phim mới"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#2C3E50"
                       Margin="0,0,0,20"/>

            <!-- FORM -->
            <Grid Grid.Row="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>



                <!-- LEFT COLUMN -->
                <StackPanel Grid.Column="0">

                    <TextBlock Text="Tên phim"/>
                    <TextBox x:Name="txtTenPhim"/>

                    <TextBlock Text="Mã thể loại (Nhập từ 1 dến 8)"/>
                    <TextBox x:Name="txtMaTheLoai"/>

                    <TextBlock Text="Thời lượng (phút)"/>
                    <TextBox x:Name="txtThoiLuong"/>

                    <TextBlock Text="Trạng thái"/>
                    <ComboBox x:Name="cbTrangThai">
                        <ComboBoxItem Content="DangChieu"/>
                        <ComboBoxItem Content="SapChieu"/>
                        <ComboBoxItem Content="NgungChieu"/>
                    </ComboBox>

                </StackPanel>

                <!-- RIGHT COLUMN -->
                <StackPanel Grid.Column="2">

                    <TextBlock Text="Ngày khởi chiếu"/>
                    <DatePicker x:Name="dpNgayKhoiChieu"/>

                    <TextBlock Text="Ngày kết thúc"/>
                    <DatePicker x:Name="dpNgayKetThuc"/>

                    <TextBlock Text="Số lượng người nhập"/>
                    <TextBox x:Name="txtNguoiNhap"/>

                    <TextBlock Text="Mô tả"/>
                    <TextBox x:Name="txtMoTa"
                             Height="100"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"/>

                </StackPanel>

            </Grid>

            <!-- BUTTON -->
            <Button Grid.Row="2"
                    Content="💾 Lưu phim"
                    HorizontalAlignment="Right"
                    Width="180"
                    Margin="0,25,0,0"
                    Click="BtnLuu_Click"/>

        </Grid>
    </Border>
</Window>
